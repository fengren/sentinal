{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "red",
        "name": "Downtime",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "bolt",
      "title": "MyTeamOne App Dashboard",
      "url": "/d/myteamone-app",
      "type": "link"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Status Overview",
      "type": "row"
    },
    {
      "title": "Health",
      "description": "Current probe result: UP or DOWN",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "index": 0 }, "1": { "text": "UP", "index": 1 } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#56A64B", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "title": "HTTP Status",
      "description": "Last probe HTTP response code",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_http_status_code{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#56A64B", "value": 200 },
              { "color": "#56A64B", "value": 300 },
              { "color": "#FF9830", "value": 400 },
              { "color": "#E02F44", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Response Time",
      "description": "Latest probe round-trip duration",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "#56A64B", "value": null },
              { "color": "#FF9830", "value": 1 },
              { "color": "#E02F44", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "SSL Expires In",
      "description": "Days until TLS certificate expires",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "floor((probe_ssl_earliest_cert_expiry{job=~\"$job\"} - time()) / 86400)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 14 },
              { "color": "#56A64B", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Uptime 1h",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[1h]) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 99 },
              { "color": "#56A64B", "value": 99.9 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Uptime 24h",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[24h]) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 99 },
              { "color": "#56A64B", "value": 99.9 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Uptime 7d",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[7d]) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 99 },
              { "color": "#56A64B", "value": 99.9 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Uptime 30d",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[30d]) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 99 },
              { "color": "#56A64B", "value": 99.9 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Status History",
      "description": "Green = UP, Red = DOWN. Shows every probe result over time.",
      "type": "state-timeline",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#56A64B", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "showValue": "never",
        "mergeValues": true,
        "alignValue": "center",
        "fillOpacity": 100,
        "rowHeight": 0.9,
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "title": "Response Time with Thresholds",
      "description": "Probe round-trip time. Orange line = 1s warning, Red line = 3s critical.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Warning 1s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Critical 3s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "title": "Latency Percentiles",
      "description": "P50 / P90 / P95 / P99 calculated from rolling 5m window.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "quantile_over_time(0.50, probe_duration_seconds{job=~\"$job\"}[5m])",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "quantile_over_time(0.90, probe_duration_seconds{job=~\"$job\"}[5m])",
          "legendFormat": "P90",
          "refId": "B"
        },
        {
          "expr": "quantile_over_time(0.95, probe_duration_seconds{job=~\"$job\"}[5m])",
          "legendFormat": "P95",
          "refId": "C"
        },
        {
          "expr": "quantile_over_time(0.99, probe_duration_seconds{job=~\"$job\"}[5m])",
          "legendFormat": "P99",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "none"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Timing Waterfall",
      "description": "Stacked breakdown: DNS lookup, TCP connect, TLS handshake, server processing, content transfer.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_dns_lookup_time_seconds{job=~\"$job\"}",
          "legendFormat": "DNS Lookup",
          "refId": "A"
        },
        {
          "expr": "probe_http_duration_seconds{job=~\"$job\",phase=\"connect\"}",
          "legendFormat": "TCP Connect",
          "refId": "B"
        },
        {
          "expr": "probe_http_duration_seconds{job=~\"$job\",phase=\"tls\"}",
          "legendFormat": "TLS Handshake",
          "refId": "C"
        },
        {
          "expr": "probe_http_duration_seconds{job=~\"$job\",phase=\"processing\"}",
          "legendFormat": "Server Processing",
          "refId": "D"
        },
        {
          "expr": "probe_http_duration_seconds{job=~\"$job\",phase=\"transfer\"}",
          "legendFormat": "Content Transfer",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "fillOpacity": 100,
            "stacking": { "mode": "normal" },
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "DNS Lookup" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "TCP Connect" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "TLS Handshake" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Server Processing" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#56A64B", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Content Transfer" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 102,
      "title": "Availability",
      "type": "row"
    },
    {
      "title": "Uptime Trend",
      "description": "Rolling availability percentage over time. Red zone = below 99%, orange = below 99.9%.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[$__range]) * 100",
          "legendFormat": "{{ instance }} — full range",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\"}[1h]) * 100",
          "legendFormat": "{{ instance }} — 1h rolling",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 99 },
              { "color": "#56A64B", "value": 99.9 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min"] }
      }
    },
    {
      "title": "Downtime Events",
      "description": "Number of failed probes in each 5-minute window.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count_over_time((probe_success{job=~\"$job\"} == 0)[5m:15s])",
          "legendFormat": "{{ instance }} — failed probes / 5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "color": { "fixedColor": "#E02F44", "mode": "fixed" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 103,
      "title": "SSL / TLS",
      "type": "row"
    },
    {
      "title": "Certificate Expiry Gauge",
      "description": "Days remaining on the TLS certificate.",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "floor((probe_ssl_earliest_cert_expiry{job=~\"$job\"} - time()) / 86400)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 365,
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 14 },
              { "color": "#56A64B", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Certificate Expiry Over Time",
      "description": "Track certificate expiry countdown. Alert if approaching the red zone.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 16, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=~\"$job\"} - time()) / 86400",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "always"
          },
          "thresholds": {
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 14 },
              { "color": "#56A64B", "value": 30 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 104,
      "title": "Network Details",
      "type": "row"
    },
    {
      "title": "HTTP Version",
      "description": "Last detected HTTP protocol version",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_http_version{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "match": "null", "result": { "text": "N/A" } }, "type": "special" },
            { "options": { "1.0": { "text": "HTTP/1.0" }, "1.1": { "text": "HTTP/1.1" }, "2.0": { "text": "HTTP/2" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "IP Protocol",
      "description": "IP version used for the last probe",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_ip_protocol{job=~\"$job\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "4": { "text": "IPv4" }, "6": { "text": "IPv6" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
